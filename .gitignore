# ─────────────────────────────────────────────
# OMC (oh-my-claudecode) 런타임 상태 — 매 세션 재생성
# ─────────────────────────────────────────────
.omc/
**/.omc/

# ─────────────────────────────────────────────
# IDE / 에디터
# ─────────────────────────────────────────────
.idea/
**/.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~

# ─────────────────────────────────────────────
# macOS / OS 잔여물
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─────────────────────────────────────────────
# Go (notiflex-platform/app)
# ─────────────────────────────────────────────
# 컴파일 산출물
*.exe
*.exe~
*.dll
*.so
*.dylib
# 테스트 바이너리 / 커버리지
*.test
*.out
coverage.txt
# Go workspace
go.work
go.work.sum
# 빌드 산출 바이너리 (모듈명 기반)
/notiflex-platform/app/notiflex
/notiflex-platform/app/main
bin/
dist/

# ─────────────────────────────────────────────
# Docker / 빌드
# ─────────────────────────────────────────────
*.tar
*.tar.gz

# ─────────────────────────────────────────────
# Kubernetes / 시크릿 (실수 커밋 방지)
# ─────────────────────────────────────────────
*.kubeconfig
kubeconfig
*-secret.yaml
*.secret.yaml
# 단, 책 교재의 시크릿 *관리 문서*(decision-guides 등 .md)는 무시 대상 아님

# ─────────────────────────────────────────────
# 환경 변수 / 자격증명
# ─────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
!**/*.pub
credentials.json
service-account*.json
gcp-key*.json

# ─────────────────────────────────────────────
# 로그 / 임시
# ─────────────────────────────────────────────
*.log
logs/
tmp/
.cache/
